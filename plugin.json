  "settings": "./CodexBarSettings.qml",
  "startupCheck": "./StartupCheck.qml",
  "icon": "speed",
  "requires_dms": ">=1.5.0",
  "requires": ["codexbar", "jq"],
  "dependencies": ["codexbar"],
  "permissions": ["settings_read", "settings_write", "process"]
}
