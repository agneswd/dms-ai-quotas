{
  "id": "codexbar",
  "name": "CodexBar",
  "description": "AI coding provider usage limits (Codex, Claude, Cursor, DeepSeek, OpenCode, etc.) in your bar.",
  "version": "1.0.0",
  "author": "agneswd",
  "type": "composite",
  "capabilities": ["dankbar-widget", "daemon"],
  "components": {
    "daemon": "./CodexBarDaemon.qml",
